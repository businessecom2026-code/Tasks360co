modules = ["nodejs-18"]

# Roda o build para garantir que a pasta dist esteja atualizada e inicia o servidor
run = "npm run build && node server.js"

entrypoint = "server.js"

[nix]
channel = "stable-23_05"
packages = ["psmisc"]

[env]
NODE_ENV = "production"
TZ = "UTC"

# Define a porta 3000 como a ÚNICA e PRINCIPAL
[[ports]]
localPort = 3000
externalPort = 443
default = true

[agent]
expertMode = true

[deployment]
deploymentTarget = "cloudrun"
publicDir = "dist/public"
