generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  GESTOR
  COLABORADOR
  CLIENTE
}

enum WorkspaceRole {
  GESTOR
  COLABORADOR
  CLIENTE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  DONE
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum RecordingStatus {
  IDLE
  RECORDING
  PAUSED
  STOPPED
  PROCESSING
  DONE
  FAILED
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                   String       @id @default(cuid())
  name                 String
  email                String       @unique
  password             String
  role                 Role         @default(COLABORADOR)
  avatar               String?
  activeWorkspaceId    String?
  activeWorkspace      Workspace?   @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id])
  googleAccessToken    String?
  googleRefreshToken   String?
  googleTokenExpiresAt DateTime?
  memberships          Membership[]
  assignedTasks        Task[]       @relation("AssignedTasks")
  notifications        Notification[]
  emailVerified        Boolean      @default(false)
  verificationToken    String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Workspace {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  memberships  Membership[]
  tasks        Task[]
  meetings     Meeting[]
  subscription Subscription?
  activeUsers  User[]         @relation("ActiveWorkspace")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Membership {
  id              String        @id @default(cuid())
  userId          String?
  workspaceId     String
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roleInWorkspace WorkspaceRole @default(COLABORADOR)
  inviteAccepted  Boolean       @default(false)
  paymentStatus   PaymentStatus @default(PENDING)
  costPerSeat     Float         @default(3.00)
  invitedEmail    String?
  revolutOrderId  String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([userId, workspaceId])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     String?      // LOW, MEDIUM, HIGH, URGENT
  labels       Json?        // Array of { name, color }
  checklist    Json?        // Array of { id, text, checked, parentId? }
  coverColor   String?
  assigneeId   String?
  assignee     User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dueDate      DateTime?
  image        String?
  color        String?
  googleTaskId String?
  lastSyncedAt DateTime?
  version      Int          @default(1)
  attachments  Attachment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileType     String   // image/png, application/pdf, video/mp4, etc.
  fileSize     Int      // bytes
  thumbnailUrl String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([taskId])
}

model Meeting {
  id             String             @id @default(cuid())
  title          String
  date           String
  time           String
  participants   String[]
  link           String?
  platform       String?
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recordingUrl   String?
  summary        String?
  suggestedTasks Json?
  recordWithAi   Boolean            @default(false)
  recordings     RecordingSession[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model RecordingSession {
  id              String          @id @default(cuid())
  meetingId       String
  meeting         Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  status          RecordingStatus @default(IDLE)
  startedAt       DateTime?
  pausedAt        DateTime?
  stoppedAt       DateTime?
  totalDurationMs Int             @default(0)
  audioUrl        String?
  processingJobId String?
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([meetingId])
}

model Subscription {
  id                String    @id @default(cuid())
  workspaceId       String    @unique
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  basePrice         Float     @default(5.00)
  seatCount         Int       @default(1)
  totalMonthlyValue Float     @default(5.00)
  autoRenew         Boolean   @default(true)
  status            SubStatus @default(ACTIVE)
  currentPeriodEnd  DateTime?
  revolutOrderId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  type        String   // task_assigned, task_moved, invite_received, meeting_created, etc.
  title       String
  body        String?
  read        Boolean  @default(false)
  data        Json?    // Extra payload (taskId, meetingId, etc.)
  createdAt   DateTime @default(now())

  @@index([userId, read])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
