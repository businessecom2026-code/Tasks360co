# ─── Database (Replit PostgreSQL / Neon) ──────────────────
# Produção — URL principal do Replit PostgreSQL
DATABASE_URL="postgresql://user:pass@host:5432/task360_prod"

# Teste — mesma instância, database diferente
DATABASE_URL_TEST="postgresql://user:pass@host:5432/task360_test"

# ─── Auth & Admin ─────────────────────────────────────────
SUPER_ADMIN="Admin@360!"
ADMIN_EMAIL="admin@ecom360.co"
JWT_SECRET="CHANGE-ME-IN-PRODUCTION"

# ─── Server ───────────────────────────────────────────────
PORT=3000
APP_URL="https://your-repl.replit.app"

# ─── Integrações (opcional) ───────────────────────────────
GEMINI_API_KEY=""
REVOLUT_API_KEY=""
RESEND_API_KEY=""
